<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/of_background"
    android:orientation="vertical">

    <!-- Normal toolbar -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/toolbarNormal"
            android:layout_width="match_parent"
            android:layout_height="@dimen/toolbar_height"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/ripple_circle"
                android:contentDescription="@string/cancel"
                android:src="@drawable/ic_back"
                app:tint="@color/of_text_primary" />

            <TextView
                android:id="@+id/toolbarTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/of_accent"
                android:textSize="24sp"
                android:textStyle="bold"
                android:visibility="invisible" />

            <ImageButton
                android:id="@+id/btnSearch"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/ripple_circle"
                android:contentDescription="@string/search"
                android:src="@drawable/ic_search"
                app:tint="@color/of_text_primary" />

            <ImageButton
                android:id="@+id/btnMore"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/ripple_circle"
                android:contentDescription="@string/more"
                android:src="@drawable/ic_more"
                app:tint="@color/of_text_primary" />
        </LinearLayout>

        <!-- Selection toolbar -->
        <LinearLayout
            android:id="@+id/toolbarSelect"
            android:layout_width="match_parent"
            android:layout_height="@dimen/toolbar_height"
            android:background="@color/of_background"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/screen_margin"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/selectAllBox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/selectAllCheck"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:contentDescription="@string/all" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/all"
                    android:textColor="@color/of_text_primary"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/selectCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_weight="1"
                android:textColor="@color/of_text_primary"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnCancelSelect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/ripple_item"
                android:padding="8dp"
                android:text="@string/cancel"
                android:textColor="@color/of_text_primary"
                android:textSize="19sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnFavorite"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/ripple_circle"
                android:contentDescription="@null"
                android:src="@drawable/ic_star_outline"
                app:tint="@color/of_text_primary" />
        </LinearLayout>
    </FrameLayout>

    <!-- Breadcrumb -->
    <HorizontalScrollView
        android:id="@+id/breadcrumbScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/screen_margin"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/breadcrumbBar"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:gravity="center_vertical"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <!-- Filter / sort row -->
    <LinearLayout
        android:id="@+id/sortRow"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/screen_margin">

        <LinearLayout
            android:id="@+id/btnFilter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/ripple_item"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="6dp">

            <TextView
                android:id="@+id/filterLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_all"
                android:textColor="@color/of_text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginStart="8dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_dropdown"
                app:tint="@color/of_text_primary" />
        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:id="@+id/btnSort"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/ripple_item"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="6dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_sort"
                app:tint="@color/of_text_primary" />

            <TextView
                android:id="@+id/sortLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/sort_name"
                android:textColor="@color/of_text_primary"
                android:textSize="17sp" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_marginHorizontal="14dp"
            android:background="@color/of_divider" />

        <ImageButton
            android:id="@+id/btnSortDir"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/ripple_circle"
            android:contentDescription="@null"
            android:src="@drawable/ic_arrow_up"
            app:tint="@color/of_text_primary" />
    </LinearLayout>

    <!-- File list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/fileList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        android:scrollbars="vertical" />

    <TextView
        android:id="@+id/emptyView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="@string/empty_folder"
        android:textColor="@color/of_accent"
        android:textSize="18sp"
        android:visibility="gone" />

    <!-- Bottom action bar (selection mode) -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/of_background"
        android:orientation="horizontal"
        android:paddingVertical="6dp"
        android:visibility="gone" />
</LinearLayout>
