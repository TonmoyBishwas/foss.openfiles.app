<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/of_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Top action row: search + more, right aligned -->
        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/toolbar_height"
            android:gravity="end|center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp">

            <ImageButton
                android:id="@+id/btnSearch"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/ripple_circle"
                android:contentDescription="@string/search"
                android:src="@drawable/ic_search"
                app:tint="@color/of_text_primary"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

            <ImageButton
                android:id="@+id/btnMore"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/ripple_circle"
                android:contentDescription="@string/more"
                android:src="@drawable/ic_more"
                app:tint="@color/of_text_primary"
                xmlns:app="http://schemas.android.com/apk/res-auto" />
        </LinearLayout>

        <!-- Recents -->
        <TextView
            android:id="@+id/recentTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/screen_margin"
            android:layout_marginTop="24dp"
            android:textColor="@color/of_text_primary"
            android:textSize="26sp"
            android:textStyle="bold"
            android:text="@string/recent_files" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recentList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:clipToPadding="false"
            android:paddingHorizontal="@dimen/screen_margin"
            android:orientation="horizontal"
            android:scrollbars="none" />

        <!-- Categories -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/screen_margin"
            android:layout_marginTop="36dp"
            android:textColor="@color/of_text_primary"
            android:textSize="@dimen/section_title_size"
            android:textStyle="bold"
            android:text="@string/categories" />

        <GridLayout
            android:id="@+id/categoryGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="12dp"
            android:columnCount="3" />

        <!-- Storage -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/screen_margin"
            android:layout_marginTop="32dp"
            android:textColor="@color/of_text_primary"
            android:textSize="@dimen/section_title_size"
            android:textStyle="bold"
            android:text="@string/storage" />

        <LinearLayout
            android:id="@+id/storageList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical" />

        <!-- Utilities -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/screen_margin"
            android:layout_marginTop="32dp"
            android:textColor="@color/of_text_primary"
            android:textSize="@dimen/section_title_size"
            android:textStyle="bold"
            android:text="@string/utilities" />

        <LinearLayout
            android:id="@+id/utilityList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
